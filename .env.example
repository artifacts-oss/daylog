TAG_NAME=latest # or your preferred tag of daylog in docker hub https://hub.docker.com/repository/docker/davidartifacts/daylog/tags

INTERNAL_APP_URL='http://localhost:3000' # set internal app url for reverse proxy
NEXT_PUBLIC_APP_URL='http://localhost:3000' # for local deployment or 'https://yourdomain.com' for production

POSTGRES_DB=daylog
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=db # or host name of your postgres database like 'localhost' or '127.0.0.1'
POSTGRES_PORT=5432 # or port of your postgres database

DATABASE_URL="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}?schema=public" # Example database URL, replace with your own
ENVIRONMENT='production' # or 'development' for local development
STORAGE_PATH='./storage'

# SMTP configuration for sending emails
#SMTP_SERVER_HOST='example.host.server'
#SMTP_SERVER_PORT=587
#SMTP_SERVER_USER='example@server.email'
#SMTP_SERVER_PASS='password'

# Unsplash API access key for fetching images
#UNSPLASH_ACCESS_KEY='your_unsplash_access_key_here'

# S3 configuration for file storage
#S3_ENDPOINT='your_s3_endpoint_here' # e.g., 'https://s3.us-east-005.backblazeb2.com'
#S3_ACCESS_KEY_ID='your_s3_access_key_id_here'
#S3_SECRET_ACCESS_KEY='your_s3_secret_access_key_here'
#S3_BUCKET='your_s3_bucket_name_here'
#S3_REGION='your_s3_region_here'

SHOW_SPONSOR_FOOTER='true'

# Field encryption master key — required to enable per-user encryption
# Generate with: openssl rand -hex 32
#ENCRYPTION_MASTER_KEY='your_64_char_hex_key_here'

# Redis — required for real-time collaborative editing
# Self-hosted:  REDIS_URL='redis://localhost:6379'
# With auth:    REDIS_URL='redis://:yourpassword@localhost:6379'
# TLS (Upstash, Redis Cloud, etc.): REDIS_URL='rediss://:yourpassword@host:port'
REDIS_URL='redis://redis:6379' # matches the docker-compose service name
#REDIS_URL='redis://localhost:6379' # if running the app outside Docker
# TLS (Upstash, Redis Cloud, etc.): REDIS_URL='rediss://:yourpassword@host:port'
